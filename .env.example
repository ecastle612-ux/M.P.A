# Web — see apps/web/.env.example for the full PR-001 matrix
NEXT_PUBLIC_APP_NAME=MPA
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MPA_ENV=development
NEXT_PUBLIC_MPA_VERSION=1.0.0-beta
NEXT_PUBLIC_MPA_BUILD=local
NEXT_PUBLIC_DESIGN_PARTNER_MODE=true

# Supabase (DEV project only in local files)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Auth/session
SESSION_COOKIE_NAME=mpa_session

# Development-only master administrator bootstrap (unset in staging/production)
DEV_MASTER_ADMIN_PASSWORD=replace-me

# Notifications (API-001) — server-only secrets; never commit real values
NOTIFICATION_PROVIDER=noop
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
ONESIGNAL_USER_AUTH_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=

# Screening (API-003)
SCREENING_PROVIDER=noop
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
CHECKR_MODE=sandbox
CHECKR_PACKAGE=
CHECKR_ALLOW_SIMULATE=true

# Signatures (API-004)
SIGNATURE_PROVIDER=noop
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_WEBHOOK_SECRET=
DROPBOX_SIGN_MODE=sandbox
DROPBOX_SIGN_ALLOW_SIMULATE=true

# Payments (API-005)
PAYMENT_PROVIDER=noop
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=sandbox
STRIPE_ALLOW_SIMULATE=true

# Email (INT-303 Resend) / SMS (INT-302 not shipped)
EMAIL_PROVIDER=noop
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_ENVIRONMENT=development
# RESEND_MODE=sandbox  # legacy alias for EMAIL_ENVIRONMENT
SMS_PROVIDER=noop
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MODE=sandbox
