{
  "name": "mpa-platform",
  "version": "1.0.0",
  "private": true,
  "description": "M.P.A. AI Property Operations Platform - Foundation scaffold",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs \"apps/*/src/**/*.ts\" \"apps/*/src/**/*.tsx\" \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\"",
    "check:circular": "depcruise --config .dependency-cruiser.cjs --include-only \"^(apps|packages)/.*/src/\" --output-type err \"apps/*/src\" \"packages/*/src\"",
    "deps:validate": "pnpm dedupe --check && pnpm list -r --depth 0 --prod"
  },
  "devDependencies": {
    "dependency-cruiser": "18.1.0",
    "prettier": "3.9.5",
    "turbo": "2.10.4",
    "typescript": "5.9.2"
  }
}
