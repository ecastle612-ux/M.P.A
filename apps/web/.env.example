# =============================================================================
# M.P.A. Web — environment template (PR-001)
# Copy to .env.local for development. Never commit real secrets.
# =============================================================================

# --- App / domain ---
NEXT_PUBLIC_APP_NAME=MPA
# Development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Staging example:
# NEXT_PUBLIC_APP_URL=https://staging.my-property-assistant.com
# Production (canonical):
# NEXT_PUBLIC_APP_URL=https://www.my-property-assistant.com

# Deployment meta (Design Partner / Private Beta chrome)
NEXT_PUBLIC_MPA_ENV=development
NEXT_PUBLIC_MPA_VERSION=1.0.0-beta
NEXT_PUBLIC_MPA_BUILD=local
NEXT_PUBLIC_DESIGN_PARTNER_MODE=true
# NEXT_PUBLIC_FEEDBACK_URL=https://forms.example.com/mpa-feedback

# --- Supabase (use a DEV project locally — never production keys in .env.local) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

SESSION_COOKIE_NAME=mpa_session

# Development-only master administrator bootstrap (UNSET in staging/production)
DEV_MASTER_ADMIN_PASSWORD=replace-me

# --- Notifications (API-001) ---
# Local/CI: noop. Production Design Partner: onesignal + prod App ID + App API Key (os_v2_app_…).
# ONESIGNAL_API_KEY is preferred. ONESIGNAL_REST_API_KEY is an accepted alias (same App API Key).
NOTIFICATION_PROVIDER=noop
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
ONESIGNAL_REST_API_KEY=
ONESIGNAL_USER_AUTH_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=

# --- Screening (API-003) ---
SCREENING_PROVIDER=noop
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
CHECKR_MODE=sandbox
CHECKR_PACKAGE=
CHECKR_ALLOW_SIMULATE=true

# --- Signatures (API-004) ---
SIGNATURE_PROVIDER=noop
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_WEBHOOK_SECRET=
DROPBOX_SIGN_MODE=sandbox
DROPBOX_SIGN_ALLOW_SIMULATE=true

# --- Payments (API-005) — tenant rent ---
PAYMENT_PROVIDER=noop
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=sandbox
STRIPE_ALLOW_SIMULATE=true
STRIPE_CONNECT_MODE=platform

# --- SaaS Billing (BILL-001) — PM company subscriptions (separate from rent/Connect) ---
SAAS_BILLING_PROVIDER=noop
# Prefer a dedicated webhook secret for /api/webhooks/saas/stripe
STRIPE_SAAS_WEBHOOK_SECRET=
STRIPE_SAAS_TRIAL_DAYS=14
STRIPE_SAAS_PRICE_FOUNDER_MONTHLY=
STRIPE_SAAS_PRICE_FOUNDER=
STRIPE_SAAS_PRICE_FOUNDER_ANNUAL=
STRIPE_SAAS_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_SAAS_PRICE_PRO=
STRIPE_SAAS_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_SAAS_PRICE_BUSINESS_MONTHLY=
STRIPE_SAAS_PRICE_BUSINESS=
STRIPE_SAAS_PRICE_BUSINESS_ANNUAL=
STRIPE_SAAS_PRICE_ENTERPRISE_MONTHLY=
STRIPE_SAAS_PRICE_ENTERPRISE=
STRIPE_SAAS_PRICE_ENTERPRISE_ANNUAL=

# --- Email (Resend) — INT-303 EmailProvider (noop | resend) ---
# Password reset remains Supabase Auth (not Resend). Never use NEXT_PUBLIC_ for RESEND_API_KEY.
EMAIL_PROVIDER=noop
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_ENVIRONMENT=development
# Legacy alias still accepted by health labeling:
# RESEND_MODE=sandbox

# --- SMS (Twilio) — INT-302 adapter not shipped; leave noop for Design Partners ---
SMS_PROVIDER=noop
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MODE=sandbox

# --- Maps (optional) ---
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Restrict HTTP referrers to production + staging hosts in Google Cloud Console.

# =============================================================================
# Production Vercel checklist (do not paste secrets here)
# - NEXT_PUBLIC_APP_URL=https://www.my-property-assistant.com
# - NEXT_PUBLIC_MPA_ENV=production
# - NEXT_PUBLIC_DESIGN_PARTNER_MODE=true
# - Dedicated production Supabase project
# - Provider webhooks/redirects point at www host
# - *_ALLOW_SIMULATE=false for live payment/screening/signature
# - DEV_MASTER_ADMIN_PASSWORD unset
# =============================================================================
